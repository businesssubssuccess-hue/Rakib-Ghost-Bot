# ===========================================================
# Ghost Net Bot — Environment Variables
# Render Dashboard ▸ Environment ▸ Add Environment Variable
# এ এই variable গুলো set করো (file টা GitHub এ push হবে না)
# ===========================================================

# Production mode
NODE_ENV=production

# Render এর external port (Render auto-set করে — manually দিতে হবে না)
# PORT=10000

# Bot এর internal dashboard port
BOT_PORT=8080

# Optional — Facebook account credentials (auto-refresh এর জন্য)
# FB_EMAIL=your_facebook_email
# FB_PASSWORD=your_facebook_password
