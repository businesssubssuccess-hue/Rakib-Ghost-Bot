        <span class="gn-cmd-cat-label">Events</span>
      </div>
    </div>
    <div class="text-center mt-4">
      <a href="/dashboard" class="gn-btn gn-btn-primary">
        <i class="fas fa-list"></i> View All Commands
      </a>
    </div>
  </div>
</section>

<!-- ═══════════════ HOW TO USE ═══════════════ -->
<section class="gn-section">
  <div class="container">
    <div class="row align-items-center g-5">
      <div class="col-lg-5">
        <h2 class="gn-section-title">🚀 How to Use</h2>
        <p class="gn-section-sub">3 simple steps to get started</p>

        <div class="gn-how-step">
          <div class="gn-step-num">1</div>
          <div class="gn-step-content">
            <h5>Add Bot to Your Group</h5>
            <p>Click "Add Bot to Group" above or search the bot's Facebook ID and add it as a member.</p>
          </div>
        </div>
        <div class="gn-how-step">
          <div class="gn-step-num">2</div>
          <div class="gn-step-content">
            <h5>Use Prefix <code class="gn-code">.</code></h5>
            <p>All commands start with a dot. Type <code class="gn-code">.help</code> to see all available commands.</p>
          </div>
        </div>
        <div class="gn-how-step">
          <div class="gn-step-num">3</div>
          <div class="gn-step-content">
            <h5>Manage via Dashboard</h5>
            <p>Login here to customize welcome messages, rank system, and more for your groups.</p>
          </div>
        </div>
      </div>

      <div class="col-lg-7">
        <div style="background:rgba(0,0,0,0.3); border:1px solid rgba(255,255,255,0.1); border-radius:16px; padding:24px; font-family:monospace; font-size:0.88rem;">
          <div style="color:#888; margin-bottom:12px;">💡 Quick Command Examples:</div>
          <div style="color:#2BFF88; margin-bottom:8px;">. h e l p</div>
          <div style="color:#aaa; margin-bottom:16px; padding-left:14px;">→ সব command এর list দেখো</div>

          <div style="color:#2BFF88; margin-bottom:8px;">. a i  [question]</div>
          <div style="color:#aaa; margin-bottom:16px; padding-left:14px;">→ AI কে যেকোনো কিছু জিজ্ঞেস করো</div>

          <div style="color:#FA8BFF; margin-bottom:8px;">. e d i t o r  4k + dark:0.4 + text:Ghost Net + style:neon</div>
          <div style="color:#aaa; margin-bottom:16px; padding-left:14px;">→ AI image editor — 4K + text + effects</div>

          <div style="color:#FA8BFF; margin-bottom:8px;">. x d m u  @mention</div>
          <div style="color:#aaa; margin-bottom:16px; padding-left:14px;">→ গালি দাও (100টা, 3s পর unsend)</div>

          <div style="color:#2BD2FF; margin-bottom:8px;">. s i n g  [song name]</div>
          <div style="color:#aaa; margin-bottom:16px; padding-left:14px;">→ গান বাজাও</div>

          <div style="color:#FFD700; margin-bottom:8px;">. r a n k</div>
          <div style="color:#aaa; margin-bottom:0; padding-left:14px;">→ তোমার rank card দেখো</div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ═══════════════ OWNER ═══════════════ -->
<section class="gn-section gn-section-dark">
  <div class="container">
    <div class="text-center">
      <h2 class="gn-section-title">👑 Bot Owner & Developer</h2>
      <p class="gn-section-sub">The person behind Ghost Net Bot</p>
    </div>
    <div class="row justify-content-center">
      <div class="col-md-6 col-lg-4">
        <div class="gn-owner-card">
          <img
            src="https://graph.facebook.com/61575436812912/picture?type=large&width=200&height=200"
            alt="Rakib Islam"
            class="gn-owner-avatar"
            onerror="this.src='/images/logo.png'"
          >
          <div class="gn-owner-name">Rakib Islam</div>
          <div style="color:#888; font-size:0.9rem; margin:6px 0 16px;">Acs Rákíb &bull; Ghost Net</div>

          <div style="margin-bottom:18px;">
            <span class="gn-badge gold">👑 Bot Owner</span>
            <span class="gn-badge pink">Developer</span>
            <span class="gn-badge green">Bangladesh 🇧🇩</span>
          </div>

          <p style="color:#888; font-size:0.88rem; margin-bottom:20px;">
            Creator of Ghost Net Edition — custom GoatBot V2 with 558+ commands,
            Bengali fun features, image editor, AI integration, and much more.
          </p>

          <a href="https://www.facebook.com/acs.rakib" target="_blank" class="gn-btn gn-btn-primary" style="font-size:0.9rem; padding:10px 26px;">
            <i class="fab fa-facebook"></i> Facebook Profile
          </a>
          <a href="https://m.me/acs.rakib" target="_blank" class="gn-btn gn-btn-outline" style="font-size:0.9rem; padding:10px 26px;">
            <i class="fab fa-facebook-messenger"></i> Message
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ═══════════════ CTA ═══════════════ -->
<section class="gn-section" style="text-align:center; padding: 70px 20px;">
  <div class="container">
    <h2 style="font-size:clamp(1.8rem,4vw,3rem); font-weight:900; color:#e8e8ff; margin-bottom:12px;">
      Ready to try Ghost Net Bot?
    </h2>
    <p style="color:#888; font-size:1.05rem; margin-bottom:28px; max-width:500px; margin-left:auto; margin-right:auto;">
      Add it to your Facebook group now and unlock 558+ powerful commands — all free!
    </p>
    <div>
      <% if (global.botID) { %>
      <a href="#" id="addme-cta" class="gn-btn gn-btn-primary" style="font-size:1.05rem; padding:14px 40px;">
        <i class="fab fa-facebook-messenger"></i> Add to Group — Free!
      </a>
      <% } %>
      <a href="/dashboard" class="gn-btn gn-btn-outline" style="font-size:1.05rem; padding:14px 40px;">
        <i class="fas fa-cog"></i> Open Dashboard
      </a>
    </div>
  </div>
</section>

<script>
(function() {
  const botID = "<%= global.botID %>";
  const openBot = () => { if (botID) window.open("https://www.facebook.com/" + botID, "_blank"); };
  const hero = document.getElementById('addme-hero');
  const cta  = document.getElementById('addme-cta');
  if (hero) hero.addEventListener('click', openBot);
  if (cta)  cta.addEventListener('click', openBot);
})();
</script>

